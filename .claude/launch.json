{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "itrm-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "itrm-backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--host", "127.0.0.1", "--port", "8077", "--log-level", "warning"],
      "port": 8077
    }
  ]
}
